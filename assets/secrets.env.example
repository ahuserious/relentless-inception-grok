# relentless-inception-grok secrets — copy to ~/.claude/relentless-inception-grok/secrets.env (chmod 600)
# Loaded by check_prereqs.sh and adversarial_review.sh; values are never printed.
# The grok (native sub-agent), claude-cli, and codex transports authenticate via their own
# subscription logins (grok login / claude auth login / codex) and need NO key here.
# Each key below only enables its matching provider-direct HTTP backend; leave unused lines blank.
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
