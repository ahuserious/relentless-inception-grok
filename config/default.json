  "native_grok": {
    "enabled": true,
    "mode": "host_handoff",
    "executor_model": "grok-4.5-latest",
    "executor_reasoning_effort": "max",
    "reviewer_models": ["grok-4.5-latest"],
    "reviewer_roles": [],
    "reasoning_only_roles": [],
    "reviewer_reasoning_effort": "max",
    "max_parallel_agents": 3,
    "inherit_workspace_context": true,
    "require_fusion_before_execution": true,
    "require_gate_after_execution": true
  },
  "profiles": {
    "maximum_intelligence": {
      "display_name": "Maximum intelligence",
      "description": "High-effort direct Grok 4.5 deliberation with generative synthesis, fail-closed verification, and a native Grok 4.5 host handoff.",
      "objective": "Deliver the most correct, complete, evidence-backed, and executable result while preserving justified dissent and user constraints.",
      "fusion": {
        "engine": "client_orchestrated",
        "panel": [
          "grok45_researcher",
          "grok45_adversary",
          "grok45_constraint_auditor"
        ],
        "optional_panel": ["openrouter_sol_pro_panel"],
        "judge": "grok45_judge",
        "synthesizer": "grok45_synthesizer",
        "native_fusion_seat": "openrouter_native_fusion_seat",
        "min_live_seats": 2,
        "max_panel_seats": 4,
        "max_concurrency": 2,
        "allow_degradation": false,
        "independent_first_pass": true,
        "anonymize_model_identity": true,
        "randomize_panel_order": true,
        "partition_context": true,
        "preserve_initial_responses": true,
        "prohibit_majority_vote": true,
        "preserve_minority_findings": true,
        "raw_panel_is_primary_evidence": true,
        "separate_no_tools_synthesis_turn": true,
        "judge_required_fields": [
          "consensus",
          "contradictions",
          "partial_coverage",
          "unique_insights",
          "minority_findings",
          "blind_spots",
          "final_guidance"
        ],
        "quality_floor": {
          "minimum_characters": 200,
          "require_nonempty_claims": true,
          "reject_tool_markup": true,
          "reject_refusal_without_policy_reason": true
        },
        "adaptive_escalation": {
          "enabled": true,
          "max_rounds": 2,
          "triggers": [
            "panel_collapse",
            "unresolved_contradictions",
            "blind_spots",
            "schema_invalid",
            "empty_response",
            "mechanical_check_failed"
          ],
          "strategy": "targeted_specialist_then_stronger_synthesizer",
          "never_repeat_open_ended_debate": true
        },
        "native_openrouter_fusion": {
          "enabled": false,
          "fallback_to_client_orchestrated": true
        }
      },
      "gates": {
        "enabled": true,
        "fail_closed": true,
        "reviewers": ["grok45_verifier", "grok45_constraint_auditor"],
        "max_concurrency": 2,
        "required_passes": 2,
        "allowed_verdicts": ["PASS", "NEEDS_WORK", "FAIL"],
        "mechanical_failure_is_blocking": true,
        "blind_spot_requires_targeted_review": true,
        "schema_failure_is_blocking": true,
        "exclude_artifact_author": true,
        "require_independent_amendment": true,
        "max_revision_cycles": 2,
        "stages": {
          "plan": {
            "enabled": true,
            "timeout_seconds": 900,
            "tool_policy": "none",
            "required_evidence": ["requirements_trace", "risk_analysis"]
          },
          "pre_execution": {
            "enabled": true,
            "timeout_seconds": 900,
            "tool_policy": "none",
            "required_evidence": ["approved_fused_plan", "scope_boundaries"]
          },
          "post_execution": {
            "enabled": true,
            "timeout_seconds": 1200,
            "tool_policy": "none",
            "required_evidence": ["diff", "tests", "requirement_coverage"]
          },
          "final": {
            "enabled": true,
            "timeout_seconds": 900,
            "tool_policy": "none",
            "required_evidence": ["gate_verdict", "cost_ledger", "provenance"]
          },
          "summarize": {
            "enabled": true,
            "timeout_seconds": 600,
            "tool_policy": "none",
            "required_evidence": ["decisions", "open_risks", "verification_state"]
          }
        }
      },
      "budgets": {
        "enforcement": "hard_stop",
        "unknown_cost_policy": "fail_closed",
        "max_calls": 40,
        "max_total_tokens": 2000000,
        "max_input_tokens": 1200000,
        "max_output_tokens": 400000,
        "max_reasoning_tokens": 400000,
        "max_tool_calls": 64,
        "max_wall_seconds": 7200,
        "max_cost_usd": 100.0,
        "approval_threshold_usd": 25.0,
        "warning_fraction": 0.8,
        "reserve_fraction_for_synthesis_and_gates": 0.3,
        "per_provider_max_cost_usd": {
          "xai_direct": 75.0,
          "openrouter": 50.0,
          "openrouter_native_fusion": 50.0,
          "trusted_router": 50.0
        }
      },
      "privacy": {
        "external_provider_access": "allow_with_redaction",
        "sensitive_path_policy": "require_user_approval",
        "sensitive_value_redaction": true,
        "redact_environment_values": true,
        "redact_git_credentials": true,
        "prompt_injection_fencing": true,
        "treat_artifacts_as_untrusted_data": true,
        "persist_raw_prompts": false,
        "persist_raw_responses": true,
        "persist_reasoning": false,
        "persist_metadata_and_hashes": true,
        "allow_provider_training": false,
        "require_zero_data_retention_when_available": true,
        "path_allowlist": [],
        "path_denylist": [".env", ".env.*", "**/*credentials*", "**/*private_key*", "**/.ssh/**"]
      },
      "evidence": {
        "require_claim_evidence": true,
        "require_primary_sources_when_available": true,
        "verify_citations": true,
        "require_mechanical_checks_for_code": true,
        "record_commands_and_exit_codes": true,
        "record_test_output": true,
        "hash_inputs_and_outputs": true,
        "preserve_raw_panel_for_synthesizer": true,
        "preserve_supported_minority": true,
        "accept_self_reported_confidence": false,
        "minimum_live_sources": 2,
        "on_unverifiable_claim": "mark_uncertain"
      },
      "rescue": {
        "enabled": true,
        "retry_attempts": 2,
        "backoff_initial_seconds": 2.0,
        "backoff_max_seconds": 30.0,
        "jitter": true,
        "semantic_failure_detection": true,
        "retry_on": ["timeout", "rate_limit", "server_error", "connection_error"],
        "fallback_on": ["empty_response", "schema_invalid", "unsupported_parameters", "policy_refusal", "tool_failure"],
        "circuit_breaker_failures": 3,
        "circuit_breaker_reset_seconds": 300,
        "panel_collapse_action": "fail_closed_and_escalate",
        "fusion_failure_action": "stronger_synthesizer_then_human",
        "budget_exhausted_action": "stop_and_report",
        "preserve_failed_attempts": true,
        "allow_degraded_single_provider": false,
        "allow_single_live_seat": false,
        "human_handoff_after_failures": 3
      },
      "execution": {
        "enabled": true,
        "mode": "grok_handoff",
        "allow_recursive_grok_cli": false,
        "grok_binary": "grok",
        "model": "grok-4.5-latest",
        "reasoning_effort": "max",
        "timeout_seconds": 3600,
        "remote_models_may_write_workspace": false,
        "require_fused_plan": true,
        "require_pre_execution_gate": true,
        "require_post_execution_gate": true,
        "require_user_approval_for_destructive_actions": true,
        "require_user_approval_for_external_writes": true,
        "preserve_unrelated_changes": true,
        "workspace_scope": "user_requested_only",
        "sandbox_mode": "workspace_write",
        "run_tests": true,
        "require_diff_review": true,
        "max_fix_cycles": 2,
        "stop_on_test_failure": false,
        "handoff_include": ["fused_plan", "constraints", "minority_findings", "blind_spots", "required_checks", "budget_remaining"],
        "completion_requires": ["requested_change", "verification_evidence", "post_execution_pass"]
      },
      "observability": {
        "enabled": false,
        "artifact_directory": ".relentless-inception/runs",
        "write_jsonl_ledger": false,
        "record_provider_and_model": true,
        "record_requested_and_actual_model": true,
        "record_route_metadata": true,
        "record_usage_and_cost": true,
        "record_latency": true,
        "record_fallbacks": true,
        "record_schema_validation": true,
        "reconcile_usage_by_generation_id": true,
        "content_logging": "metadata_only"
      }
    }
  }
}
